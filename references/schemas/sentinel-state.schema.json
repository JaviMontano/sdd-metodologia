{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Sentinel State",
  "description": "Heartbeat sentinel state for ambient intelligence",
  "type": "object",
  "required": ["enabled"],
  "properties": {
    "enabled": { "type": "boolean" },
    "lastRun": { "type": "string" },
    "runCount": { "type": "integer", "minimum": 0 },
    "intervalMinutes": { "type": "integer", "minimum": 1 },
    "suppressedUntil": { "type": ["string", "null"] },
    "findings": { "type": "array", "items": { "type": "string" } },
    "autoClosedCount": { "type": "integer", "minimum": 0 }
  }
}
