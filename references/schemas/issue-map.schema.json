{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Issue Map",
  "description": "Mapping of tasks to GitHub issues created by Phase 8",
  "type": "object",
  "required": ["created", "issues"],
  "properties": {
    "created": { "type": "string" },
    "feature": { "type": "string" },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["taskId", "issueUrl"],
        "properties": {
          "taskId": { "type": "string", "pattern": "^T-[0-9]{3,4}$" },
          "issueNumber": { "type": "integer" },
          "issueUrl": { "type": "string", "format": "uri" },
          "title": { "type": "string" },
          "labels": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
